# ===== OKX 模拟盘密钥（在 OKX > 模拟交易 生成）=====
# OKX_FLAG 必须保持 '1'（模拟盘）。实盘（flag '0'）已被 app/core/security.py 硬性禁用。
OKX_API_KEY=your-demo-api-key
OKX_API_SECRET=your-demo-api-secret
OKX_API_PASSPHRASE=your-demo-passphrase
OKX_FLAG=1

# 访问 OKX 的出站代理（如本机 Clash）。不需要代理则留空。
HTTP_PROXY=http://127.0.0.1:7897

# 看板展示的交易品种（逗号分隔）。
TRADING_INSTRUMENTS=BTC-USDT-SWAP,ETH-USDT-SWAP

# ===== 数据库（本机 MySQL）=====
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=okx
MYSQL_PASSWORD=okx_pass
MYSQL_DB=okx_dashboard

# 缓存：使用内置内存缓存，无需额外服务。
CACHE_BACKEND=memory

# 前端允许的 CORS 来源（用户看板 5910 + 后台管理系统 5911）。
CORS_ORIGINS=http://localhost:5910,http://localhost:5911
DEBUG=false

# ===== 登录 / 成员体系 =====
# 签发登录 token 的密钥，生产环境务必改成随机长字符串。
SECRET_KEY=dev-insecure-change-me-okx-quant-dashboard
# 登录有效期（分钟）。
ACCESS_TOKEN_EXPIRE_MINUTES=720
# 首次启动（数据库还没有任何用户时）自动创建的超级管理员。
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123456
